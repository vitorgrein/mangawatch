# Copie este arquivo para `.env` e preencha com as credenciais reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).

# Banco de origem (produção)
ETL_PROD_USER=usuario
ETL_PROD_PASS=senha

# Banco do datamart (onde ficam fato_daily / fato_funil)
ETL_DATAMART_USER=usuario
ETL_DATAMART_PASS=senha
